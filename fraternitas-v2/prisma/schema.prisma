generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══ AUTH ═══
model User {
  id                String    @id @default(cuid())
  name              String?
  email             String    @unique
  emailVerified     DateTime?
  image             String?
  password          String?
  role              Role      @default(USER)
  banned            Boolean   @default(false)
  bannedReason      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  profile           Profile?
  accounts          Account[]
  sessions          Session[]
  verificationTokens VerificationToken[]
  passwordResetTokens PasswordResetToken[]

  sentMessages      Message[]          @relation("SentMessages")
  conversations     ConversationMember[]
  hostedEvents      Event[]            @relation("HostedEvents")
  eventRegistrations EventRegistration[]
  ownedCircles      Circle[]           @relation("OwnedCircles")
  circleMemberships CircleMember[]
  circleMessages    CircleMessage[]
  sentConnections   Connection[]       @relation("SentConnections")
  receivedConnections Connection[]     @relation("ReceivedConnections")
  notifications     Notification[]
  auditLogs         AuditLog[]
  reports           Report[]           @relation("ReporterReports")
  reportedReports   Report[]           @relation("ReportedReports")
  blockedUsers      Block[]            @relation("BlockedBy")
  blockedByUsers    Block[]            @relation("BlockedUser")
  loginHistory      LoginHistory[]
  intentions        Intention[]
  intentionPrayers  IntentionPrayer[]

  @@index([email])
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  userAgent    String?
  ipAddress    String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  expires    DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  ipAddress String?
  userAgent String?
  location  String?
  success   Boolean
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ═══ PROFILE ═══
model Profile {
  id           String   @id @default(cuid())
  userId       String   @unique
  bio          String?  @db.Text
  city         String?
  age          Int?
  situation    String?
  practiceLevel String?
  seeking      String[] @default([])
  quote        String?
  visibility   Visibility @default(PUBLIC)
  onboarded    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  interests    ProfileInterest[]
  notificationSettings NotificationSettings?

  @@index([userId])
  @@index([city])
}

enum Visibility {
  PUBLIC
  MEMBERS
  CONNECTIONS
}

model Interest {
  id       String           @id @default(cuid())
  name     String           @unique
  emoji    String
  category String
  profiles ProfileInterest[]
}

model ProfileInterest {
  profileId  String
  interestId String
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  interest   Interest @relation(fields: [interestId], references: [id], onDelete: Cascade)

  @@id([profileId, interestId])
}

model NotificationSettings {
  id                String  @id @default(cuid())
  profileId         String  @unique
  newConnections    Boolean @default(true)
  messages          Boolean @default(true)
  events            Boolean @default(true)
  spiritualContent  Boolean @default(false)
  emailDigest       Boolean @default(true)
  profile           Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

// ═══ MESSAGES ═══
model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   ConversationMember[]
  messages  Message[]

  @@index([updatedAt])
}

model ConversationMember {
  conversationId String
  userId         String
  joinedAt       DateTime @default(now())
  lastReadAt     DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  senderId       String
  content        String      @db.Text
  imageUrl       String?
  readAt         DateTime?
  createdAt      DateTime    @default(now())
  deletedAt      DateTime?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

// ═══ EVENTS ═══
model Event {
  id          String      @id @default(cuid())
  hostId      String
  title       String
  description String      @db.Text
  type        EventType
  city        String
  address     String?
  latitude    Float?
  longitude   Float?
  imageUrl    String?
  startDate   DateTime
  endDate     DateTime?
  maxAttendees Int?
  price       Float       @default(0)
  isPublic    Boolean     @default(true)
  status      EventStatus @default(PUBLISHED)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  host          User                @relation("HostedEvents", fields: [hostId], references: [id], onDelete: Cascade)
  registrations EventRegistration[]
  reports       Report[]            @relation("EventReports")

  @@index([hostId])
  @@index([city])
  @@index([startDate])
  @@index([status])
}

enum EventType {
  REPAS
  RETRAITE
  PRIERE
  RANDONNEE
  LECTURE
  BENEVOLAT
  SPORT
  CULTURE
  PRO
  AUTRE
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

model EventRegistration {
  id        String             @id @default(cuid())
  eventId   String
  userId    String
  status    RegistrationStatus @default(CONFIRMED)
  createdAt DateTime           @default(now())

  event     Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
  @@index([eventId])
}

enum RegistrationStatus {
  CONFIRMED
  WAITLIST
  CANCELLED
}

// ═══ CIRCLES ═══
model Circle {
  id          String       @id @default(cuid())
  ownerId     String
  name        String
  description String?      @db.Text
  city        String
  imageUrl    String?
  isPrivate   Boolean      @default(false)
  rules       String?      @db.Text
  status      CircleStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  owner    User           @relation("OwnedCircles", fields: [ownerId], references: [id], onDelete: Cascade)
  members  CircleMember[]
  messages CircleMessage[]

  @@index([ownerId])
  @@index([city])
}

enum CircleStatus {
  ACTIVE
  ARCHIVED
  DISSOLVED
}

model CircleMember {
  circleId String
  userId   String
  role     CircleRole @default(MEMBER)
  joinedAt DateTime   @default(now())

  circle   Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([circleId, userId])
  @@index([userId])
}

enum CircleRole {
  MEMBER
  MODERATOR
  ADMIN
}

model CircleMessage {
  id        String   @id @default(cuid())
  circleId  String
  userId    String
  content   String   @db.Text
  imageUrl  String?
  createdAt DateTime @default(now())
  deletedAt DateTime?

  circle    Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([circleId])
  @@index([createdAt])
}

// ═══ CONNECTIONS ═══
model Connection {
  id         String           @id @default(cuid())
  senderId   String
  receiverId String
  status     ConnectionStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  sender   User @relation("SentConnections", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedConnections", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId])
  @@index([status])
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ═══ NOTIFICATIONS ═══
model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

enum NotificationType {
  CONNECTION_REQUEST
  CONNECTION_ACCEPTED
  NEW_MESSAGE
  EVENT_REMINDER
  EVENT_CANCELLED
  CIRCLE_INVITE
  CIRCLE_MESSAGE
  NEW_MEMBER_COMPATIBLE
  SYSTEM
}

// ═══ SAFETY ═══
model Report {
  id         String       @id @default(cuid())
  reporterId String
  reportedId String?
  eventId    String?
  reason     String
  details    String?      @db.Text
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())

  reporter  User   @relation("ReporterReports", fields: [reporterId], references: [id], onDelete: Cascade)
  reported  User?  @relation("ReportedReports", fields: [reportedId], references: [id])
  event     Event? @relation("EventReports", fields: [eventId], references: [id])

  @@index([reporterId])
  @@index([status])
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

model Block {
  blockerId  String
  blockedId  String
  createdAt  DateTime @default(now())

  blocker    User @relation("BlockedBy", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked    User @relation("BlockedUser", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
  @@index([blockerId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user      User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Intention {
  id          String    @id @default(cuid())
  userId      String
  type        String    @default("PRAYER")
  text        String
  massChurch  String?
  massCity    String?
  massDate    DateTime?
  city        String?
  anonymous   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  expiresAt   DateTime

  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  prayers IntentionPrayer[]
}

model IntentionPrayer {
  id          String    @id @default(cuid())
  intentionId String
  userId      String
  createdAt   DateTime  @default(now())

  intention Intention @relation(fields: [intentionId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([intentionId, userId])
}
model Defunt {
  id        String   @id @default(cuid())
  userId    String
  prenom    String
  lien      String?
  annee     Int?
  note      String?
  anonymous Boolean  @default(false)
  createdAt DateTime @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  prayers DefuntPrayer[]

  @@index([userId])
  @@index([createdAt])
}

model DefuntPrayer {
  id        String   @id @default(cuid())
  defuntId  String
  userId    String
  createdAt DateTime @default(now())

  defunt Defunt @relation(fields: [defuntId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([defuntId, userId])
  @@index([defuntId])
}
